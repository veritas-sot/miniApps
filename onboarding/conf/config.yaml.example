---
sot:
  nautobot: "__NAUTOBOT__"
  token: "__TOKEN__"
  ssl_verify: false
git:
  defaults:
    repo: __DEFAULTS_REPO__
    path: __DEFAULTS_PATH__
    filename: __DEFAULTS_FILENAME__
  backups:
    repo: __BACKUP_REPO__
    path: __BACKUP_PATH__
    subdir: __BACKUP_SUBDIR__
  app_configs:
    repo: __CONFIGS_REPO__
    path: __CONFIGS_PATH__
    subdir: __CONFIGS_SUBDIR__
  config_contexts:
    repo: __CONFIG_CONTEXT_REPO__
    path: __CONFIG_CONTEXT_PATH__
    subdir: __CONFIG_CONTEXT_SUBDIR__

directories:
  hldm: hldm
  export: export

# default logins to connect to the devices
# these accounts are not stored in nautobot
profiles:
  default:
      # username to login to devices
      username: "__USERNAME__"
      # encrypted and base64 encoded password
      password: "__PASSWORD__"

general:
  logging:
    # config: ./conf/logging.ini
    loglevel: info
    color: false
    # format: "%(levelname)s - %(message)s"
    format: "%(asctime)s - %(filename)s:%(funcName)s:%(lineno)d %(levelname)-s - %(message)s"
    # format: "%(asctime)s - %(filename)s:%(funcName)s:%(lineno)d %(log_color)s%(levelname)-s%(reset)s - %(message)s"
    handler: stdout
    logtodatabase: false
    database:
      host: __database_host__
      database: __database_datbase__
      user: __database_username__
      password: __database_password__
      port: __database_port__
onboarding:
  defaults:
    # the default primary interface we use to get the primary address
    interface:
      - Loopback0
      - Loopback100
      - mgmt0
      - Vlan10
  mappings:
    # loading mapping from app config (see above)
    inventory:
      filename: inventory.yaml
  offline_config:
    model: unknown
    serial: offline
    platform: ios
    primary_interface: Loopback100
    primary_mask: 255.255.255.255
    primary_description: Primary
    filename: ./conf/offline.conf