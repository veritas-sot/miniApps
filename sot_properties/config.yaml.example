---
sot:
  nautobot: "__NAUTOBOT__"
  token: "__TOKEN__"
  ssl_verify: false
files:
  prefixes:
    repo: sot_data
    path: __REPO_PATH__
    filename: defaults/prefixes.yaml
  defaults:
    repo: sot_data
    path: __REPO_PATH__
    filename: defaults/default_values.yaml
  sites:
    repo: sot_data
    path: __REPO_PATH__
    filename: defaults/sites.yaml
  manufacturers:
    repo: sot_data
    path: __REPO_PATH__
    filename: defaults/manufacturers.yaml
  platforms:
    repo: sot_data
    path: __REPO_PATH__
    filename: defaults/platforms.yaml
  roles:
    repo: sot_data
    path: __REPO_PATH__
    filename: defaults/roles.yaml
  device_types:
    repo: sot_data
    path: __REPO_PATH__
    filename: defaults/device_types.yaml
  location_types:
    repo: sot_data
    path: __REPO_PATH__
    filename: defaults/location_types.yaml
  locations:
    repo: sot_data
    path: __REPO_PATH__
    # you can either use yaml or xlsx files
    filename: defaults/locations.yaml
  tags:
    repo: sot_data
    path: __REPO_PATH__
    filename: defaults/tags.yaml
  custom_fields:
    repo: sot_data
    path: __REPO_PATH__
    filename: defaults/custom_fields.yaml
  custom_links:
    repo: sot_data
    filename: defaults/custom_links.yaml
  custom_field_choices:
    repo: sot_data
    path: __REPO_PATH__
    filename: defaults/custom_fields.yaml
  webhooks:
    repo: sot_data
    path: __REPO_PATH__
    filename: defaults/webhooks.yaml
device_library:
  directory: /path/to/device_types/library/
country_library:
  # source eg https://raw.githubusercontent.com/bhatvikrant/world-countries-capitals/master/data/data.json
  directory: /path/to/countries/library/all_countries.json
general:
  logging:
    loglevel: info
    logtodatabase: false
    logtozeromq: false
    database:
      host: __database_host__
      database: __database_datbase__
      user: __database_username__
      password: __database_password__
      port: __database_port__
    zeromq:
      protocol: __zeromq_protocol__
      host: __zeromq_host__
      port: __zeromq_port__
